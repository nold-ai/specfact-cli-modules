---
layout: null
permalink: /assets/js/search-index.json
---
{% assign pages_with_title = "" | split: "" %}{% for page in site.pages %}{% if page.title %}{% assign pages_with_title = pages_with_title | push: page %}{% endif %}{% endfor %}[{% for page in pages_with_title %}
  {
    "url": "{{ page.url | relative_url }}",
    "title": {{ page.title | jsonify }},
    "keywords": {{ page.keywords | default: "" | jsonify }},
    "audience": {{ page.audience | default: "" | jsonify }},
    "expertise_level": {{ page.expertise_level | default: "" | jsonify }},
    "content": {{ page.content | strip_html | truncatewords: 200 | jsonify }}
  }{% unless forloop.last %},{% endunless %}{% endfor %}
]
